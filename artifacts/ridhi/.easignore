# EAS Build Archive Exclusions
# Keeps the uploaded archive small by excluding files EAS doesn't need.
# EAS installs its own node_modules on the build server, so local ones are wasteful.

# Dependencies (largest contributor — can be 200+ MB)
node_modules/

# Expo / Metro build outputs
.expo/
dist/
web-build/
static-build/

# Native build folders (generated by EAS, not needed in archive)
ios/
android/

# Logs
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# TypeScript incremental build cache
*.tsbuildinfo

# macOS metadata
.DS_Store
**/.DS_Store

# Local environment files (secrets must not be uploaded)
.env
.env*.local

# Certificate / key files
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# Git
.git/
.gitignore

# Misc editor / OS artifacts
.vscode/
.idea/
Thumbs.db
